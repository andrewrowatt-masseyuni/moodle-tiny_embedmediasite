{{!
    @template tiny_embedmediasite/modal

    Modal dialog for browsing and inserting MediaSite presentations. Displays presentations via the _presentations partial.

    Example context (json):
    {
        "list": [
            {
                "title": "Introduction to Course Content",
                "date_formatted": "January 10, 2026",
                "duration_formatted": "45 minutes",
                "source": "https://mediasite.example.com/Mediasite/Play/abc123def456",
                "thumbnail": "https://mediasite.example.com/mediasite/api/presentations/abc123def456/thumbnail",
                "id": "abc123def456"
            },
            {
                "title": "Advanced Topics Overview",
                "date_formatted": "January 8, 2026",
                "duration_formatted": "60 minutes",
                "source": "https://mediasite.example.com/Mediasite/Play/xyz789uvw321",
                "thumbnail": "https://mediasite.example.com/mediasite/api/presentations/xyz789uvw321/thumbnail",
                "id": "xyz789uvw321"
            }
        ],
        "manage": "https:\/\/webcast.massey.ac.nz\/mediasite\/mymediasite",
        "nologin": true,
        "norefresh": true,
        "nosearch": true,
        "page": 1,
        "pages": -1
    }
}}
{{< core/modal }}
    {{$title}}
        <span class="d-flex align-items-center w-100" id="tiny_embedmediasite_title">
            <span class="mr-2 text-nowrap">{{#str}} pluginname, tiny_embedmediasite {{/str}}</span>
            <span class="input-group input-group-sm">
                <span class="position-relative flex-grow-1">
                    <input type="text" id="tiny_embedmediasite_filter" name="filter" class="form-control"
                            style="padding-right: 2rem;"
                            placeholder="{{#str}} filterplaceholder, tiny_embedmediasite {{/str}}">
                    <button class="btn btn-link btn-sm text-muted" type="button" id="tiny_embedmediasite_clear"
                            style="display: none; position: absolute; right: 0; top: 50%; transform: translateY(-50%); z-index: 4; padding: 0 .4rem;"
                            aria-label="{{#str}} clearfilter, tiny_embedmediasite {{/str}}" title="{{#str}} clearfilter, tiny_embedmediasite {{/str}}">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </span>
                <span class="input-group-append">
                    <button class="btn btn-outline-secondary" type="button" id="tiny_embedmediasite_search"
                            disabled aria-label="{{#str}} search, tiny_embedmediasite {{/str}}" title="{{#str}} search, tiny_embedmediasite {{/str}}">
                        <i class="fa-solid fa-magnifying-glass"></i>
                    </button>
                </span>
            </span>
            <a class="btn btn-link p-0 ml-1 icon-no-margin" role="button"
                data-container="body" data-toggle="popover"
                data-placement="right" data-content="{{#str}} filterhelp, tiny_embedmediasite {{/str}}"
                data-html="true" tabindex="0" data-trigger="focus"
                aria-label="{{#str}} help {{/str}}">
                {{#pix}}help, core, {{#str}} help {{/str}}{{/pix}}
            </a>
        </span>
    {{/title}}
    {{$body}}
        <div id="tiny_embedmediasite_content-container">
        {{> tiny_embedmediasite/_presentations }}
        </div>
        <div id="tiny_embedmediasite_loading"><i class="fa-solid fa-sync fa-spin"></i> {{#str}} loadingmorecontent, tiny_embedmediasite {{/str}}</div>
        <div id="tiny_embedmediasite_no_more_content" style="display: none;">{{#str}} nomorecontent, tiny_embedmediasite {{/str}}</div>
        <div id="tiny_embedmediasite_no_content_found" style="display: none;">{{#str}} nocontentfound, tiny_embedmediasite {{/str}}</div>
    {{/body}}
    {{$footer}}
        <div id="tiny_embedmediasite_footer">
            <div class="small text-muted">{{#str}} modalfooterhelptext, tiny_embedmediasite {{/str}}</div>
        </div>
    {{/footer}}
{{/ core/modal }}